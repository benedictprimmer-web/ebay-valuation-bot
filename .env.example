# Copy to .env for local live runs (never commit .env). In GitHub these are repo secrets.
# SOLD comps: The Card API key (from thecardapi.com signup, starts with tca_).
CARDAPI_KEY=tca_your-card-api-key
# LIVE auctions: RapidAPI key for the OpenWeb Ninja eBay source.
RAPIDAPI_KEY=your-rapidapi-key
# Optional fallback: official eBay Browse API production credentials (--mode browse).
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
# CallMeBot WhatsApp — from the one-time activation (see README).
CALLMEBOT_PHONE=+447000000000
CALLMEBOT_APIKEY=your-callmebot-key
